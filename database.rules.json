{
  "rules": {
    ".read": false,
    ".write": false,

    "syncPins": {
      "$pin": {
        ".read": true,
        ".write": true,
        ".validate": "newData.hasChildren(['shopId','syncVersion','masterDeviceId','active','updatedAt']) && newData.child('shopId').isString() && newData.child('syncVersion').isNumber() && newData.child('masterDeviceId').isString() && newData.child('active').isBoolean() && newData.child('updatedAt').isNumber()"
      }
    },

    "shops": {
      "$shopId": {
        "master": {
          ".read": true,
          ".write": true
        },

        "joinRequests": {
          "$clientId": {
            ".read": true,
            ".write": "newData.exists() && newData.child('clientId').val() === $clientId && newData.child('shopId').val() === $shopId && newData.child('status').val() === 'pending'"
          }
        },

        "clients": {
          "$clientId": {
            ".read": true,
            ".write": true
          }
        },

        "snapshot": {
          ".read": true,
          ".write": "newData.child('shopId').val() === $shopId"
        },

        "operations": {
          "$opId": {
            ".read": true,
            ".write": "newData.child('shopId').val() === $shopId"
          }
        },

        "events": {
          "$eventId": {
            ".read": true,
            ".write": "newData.child('shopId').val() === $shopId"
          }
        }
      }
    }
  }
}
